# /etc/sudoers.d/kai-sirens-discord-ops
#
# NOPASSWD entries so:
#   - `coily ssh systemctl restart sirens-discord-ops` (the manual deploy
#     step after `git push`) works without a sudo password prompt.
#   - `coily ssh systemctl status sirens-discord-ops` works for diagnostic
#     access without a sudo password prompt.
#
# Sudoers strict-matches command-line args, so we list each form coily
# emits explicitly. coily `status` appends --no-pager; `restart` does not.
# One rule per line so the comma-list parser doesn't mis-tokenize the
# `--no-pager` flag.
#
# Install on kai-server (one-time, done by scripts/install.sh):
#   sudo install -m 0440 -o root -g root \
#     /home/kai/projects/coilysiren/sirens-discord-ops/sudoers/kai-sirens-discord-ops \
#     /etc/sudoers.d/kai-sirens-discord-ops
#   sudo visudo -cf /etc/sudoers.d/kai-sirens-discord-ops

kai ALL=(root) NOPASSWD: /bin/systemctl restart sirens-discord-ops
kai ALL=(root) NOPASSWD: /usr/bin/systemctl restart sirens-discord-ops
kai ALL=(root) NOPASSWD: /bin/systemctl start sirens-discord-ops
kai ALL=(root) NOPASSWD: /usr/bin/systemctl start sirens-discord-ops
kai ALL=(root) NOPASSWD: /bin/systemctl stop sirens-discord-ops
kai ALL=(root) NOPASSWD: /usr/bin/systemctl stop sirens-discord-ops
kai ALL=(root) NOPASSWD: /bin/systemctl status sirens-discord-ops --no-pager
kai ALL=(root) NOPASSWD: /usr/bin/systemctl status sirens-discord-ops --no-pager
kai ALL=(root) NOPASSWD: /bin/systemctl status sirens-discord-ops
kai ALL=(root) NOPASSWD: /usr/bin/systemctl status sirens-discord-ops
